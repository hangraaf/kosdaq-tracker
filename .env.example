# ── 로컬 개발 환경변수 템플릿 ─────────────────────────────────────────────
# 사용 방법:
#   Windows: Copy-Item .env.example .env
#   Linux/Mac: cp .env.example .env
# 그 후 .env 파일을 열어 실제 값으로 채워주세요.

# PostgreSQL (docker-compose 로컬 DB)
POSTGRES_PASSWORD=localdev

# KIS (한국투자증권 Open API) — https://apiportal.koreainvestment.com
# 모의투자(paper)나 실전(prod) 중 선택
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ENV=paper

# JWT 시크릿 — 프로덕션에서는 반드시 변경할 것
SECRET_KEY=local-dev-secret-change-me

# 관리자 계정 (선택 — 설정하면 시작 시 자동 생성)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# 토스페이먼츠 결제 (선택)
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
