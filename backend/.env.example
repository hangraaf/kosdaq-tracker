# ── JWT ──────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-please-use-env
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── KIS API (한국투자증권 Open API) ────────────────────────
# https://apiportal.koreainvestment.com 에서 발급
KIS_APP_KEY=your_kis_app_key_here
KIS_APP_SECRET=your_kis_app_secret_here
KIS_ENV=prod          # prod | paper (모의투자)

# ── CORS ─────────────────────────────────────────────────
# 배포 시 실제 도메인으로 변경
# CORS_ORIGINS=["https://your-app.vercel.app"]

# ── 토스페이먼츠 ──────────────────────────────────────────
TOSS_CLIENT_KEY=test_ck_your_client_key_here
TOSS_SECRET_KEY=test_sk_your_secret_key_here

# ── OAuth (Kakao) ────────────────────────────────────────
# Kakao Developers (https://developers.kakao.com) → 내 애플리케이션 → 앱 키
# REST API 키만 필수, Client Secret은 콘솔에서 활성화한 경우에만.
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=

# OAuth 콜백 베이스 URL — 환경별로 변경
# dev:  OAUTH_BACKEND_BASE_URL=http://localhost:8000
#       OAUTH_FRONTEND_BASE_URL=http://localhost:3000
# prod: OAUTH_BACKEND_BASE_URL=https://<your-backend>.onrender.com
#       OAUTH_FRONTEND_BASE_URL=https://<your-frontend>.vercel.app
OAUTH_BACKEND_BASE_URL=http://localhost:8000
OAUTH_FRONTEND_BASE_URL=http://localhost:3000
